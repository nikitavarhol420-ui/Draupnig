# Токен от @BotFather
BOT_TOKEN=123456:ABC-DEF...
# ID Google-таблицы (из её URL)
SPREADSHEET_ID=1AbC...
# ID группового чата (отрицательное число)
GROUP_CHAT_ID=-1001234567890
# Путь к JSON-ключу service account
GOOGLE_CREDENTIALS=task_bot/service_account.json
# Участники: username:Имя через запятую
PARTICIPANTS=nick:Ник,alex:Алекс,maria:Мария
# Время прогонов напоминаний и еженедельной сводки (HH:MM, 24ч)
DAILY_CHECK_TIME=11:00        # утро: «за 2 дня» и «в день», текст скрыт спойлером
EVENING_TODAY_TIME=20:00      # вечер: «за 1 день» и «в день»
OVERDUE_TIME=20:30            # просрочка: каждый день, пока не закрыта
WEEKLY_REPORT_TIME=09:00
